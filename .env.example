# Copie para .env.local e preencha.
# Validado em runtime por src/config/env.ts.

# --- Público (exposto ao browser) ---
# Os valores abaixo são os defaults do Supabase local (`supabase start`).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Privado (server-only) ---
# Nunca commitar. Usado apenas em ações administrativas (convite de usuário, etc.).
SUPABASE_SERVICE_ROLE_KEY=

# Opcional — usado pela CLI do Supabase para migrations/psql.
DATABASE_URL=
